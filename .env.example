# Copy to .env and fill in. Never commit .env.
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
GOOGLE_PLACES_API_KEY=
YELP_API_KEY=
# Optional: use a different public/private Overpass instance for OSM discovery.
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Public URL of the FastAPI server, reachable by ElevenLabs webhook tools.
# For local dev: run `ngrok http 8000` and paste the https URL here,
# then re-run `python -m agents.provision` so tools point at it.
PUBLIC_BASE_URL=https://YOUR-TUNNEL.ngrok-free.app

# For REAL outbound phone calls (live negotiation demo): import a Twilio
# number in the ElevenLabs dashboard (Phone Numbers) and paste its id here.
ELEVENLABS_PHONE_NUMBER_ID=

# Global safe mode for bulk scheduling. When true, real Google vendor records
# produce structured synthetic transcripts only: no dial, no agents, no audio.
DEBUG_CALLS=true
LIVE_VENDOR_CALLS_ENABLED=false

# Allow-listed destination for the explicit live demo endpoint. Keep the real
# personal number in .env only; never commit it here.
DEMO_PHONE_NUMBER=

# Maximum time to wait for every member of a real telephony batch.
CALL_BATCH_TIMEOUT_SECS=900
CALL_POLL_INTERVAL_SECS=2
CALL_RUN_LEASE_SECS=2100
MAX_VENDOR_RECALLS=2

# Shared only by FastAPI and provisioned ElevenLabs webhook tools. Generate
# with `openssl rand -hex 32`; never expose it to Lovable/browser code.
AGENT_TOOL_SECRET=

# Which domain sheet to load from verticals/ as the process default
# (jobs can still target any sheet via POST /api/jobs {vertical, area_code}).
# MVP domain: plumbing. Re-run `python -m agents.provision` after changing.
VERTICAL=plumbing
