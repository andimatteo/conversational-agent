# Copy to .env and fill in. Never commit .env.
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=

# Public URL of the FastAPI server, reachable by ElevenLabs webhook tools.
# For local dev: run `ngrok http 8000` and paste the https URL here,
# then re-run `python -m agents.provision` so tools point at it.
PUBLIC_BASE_URL=https://YOUR-TUNNEL.ngrok-free.app

# Which vertical pack to load from verticals/
VERTICAL=moving
